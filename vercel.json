{
  "version": 2,
  "buildCommand": "npm install -g pnpm && pnpm install --no-frozen-lockfile && pnpm vite build",
  "outputDirectory": "dist/public",
  "installCommand": "npm install -g pnpm && pnpm install --no-frozen-lockfile",
  "framework": null,
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
