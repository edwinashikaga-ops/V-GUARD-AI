# ============================================================
# V-Guard AI — Environment Variables
# Set these in: Vercel Dashboard > Project > Settings > Environment Variables
# ============================================================

# App Config
NODE_ENV=production

# Database (MySQL - e.g. Railway, PlanetScale, Aiven)
DATABASE_URL=mysql://user:password@host:port/vguard_db

# Security
JWT_SECRET=your_super_secret_jwt_key_min_32_chars

# Optional: OAuth (if using SSO)
# OAUTH_SERVER_URL=
# OWNER_OPEN_ID=

# Optional: Storage (S3 compatible)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=
# AWS_BUCKET_NAME=
